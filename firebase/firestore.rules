rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Plants and companion rules — any authenticated user can read
    match /plants/{plantId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /companion_rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Mauritius regions — publicly readable
    match /mauritius_regions/{regionId} {
      allow read: if true;
      allow write: if false;
    }

    // User profile — owner only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Gardens — owner only
    match /gardens/{gardenId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      // Layouts subcollection
      match /layouts/{layoutId} {
        allow read, write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/gardens/$(gardenId)).data.userId;
      }

      // Beds subcollection
      match /beds/{bedId} {
        allow read, write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/gardens/$(gardenId)).data.userId;
      }
    }

    // Tasks — owner only
    match /tasks/{taskId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }

    // Calendars — owner only
    match /calendars/{calendarId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
    }
  }
}
