# ============================================================
# GardNx Backend – copy to .env and fill in your values
# Never commit the real .env file to version control
# ============================================================

# Path to Firebase service-account credentials JSON
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Firebase Storage bucket (without gs:// prefix)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Path to trained DeepLabV3+ model weights (.pth)
# If missing, the server starts in mock mode automatically
MODEL_WEIGHTS_PATH=./app/ml/weights/deeplabv3_garden.pth

# Force mock mode even when weights file exists (good for dev/CI)
USE_MOCK_MODEL=true

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Open-Meteo historical archive URL (free, no key required)
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# Perenual Plant API key — get a free key at https://perenual.com/docs/api
# Free tier: 100 requests/day. Used to enrich plant data with images and descriptions.
PERENUAL_API_KEY=your-perenual-api-key-here
