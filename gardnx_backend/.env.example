# ============================================================
# GardNx Backend — copy this file to .env and fill in values
# NEVER commit the real .env file to version control
# ============================================================

# ------------------------------------------------------------------
# Firebase
# Download service account key from:
#   Firebase Console → Project Settings → Service Accounts
#                    → Generate new private key
# Save it as firebase-credentials.json in this same folder.
# ------------------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Find this in Firebase Console → Project Settings → General
# Looks like: your-project-id.firebasestorage.app  (no gs:// prefix)
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ------------------------------------------------------------------
# ML Model
# true  = mock mode (recommended — no GPU or weights file needed)
# false = real HuggingFace segmentation (requires HF_API_TOKEN below)
# ------------------------------------------------------------------
USE_MOCK_MODEL=true
MODEL_WEIGHTS_PATH=./app/ml/weights/deeplabv3_garden.pth

# ------------------------------------------------------------------
# Server
# HOST=0.0.0.0 is required so your phone can reach the backend
# over Wi-Fi. Do not change this to localhost.
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ------------------------------------------------------------------
# External APIs
# ------------------------------------------------------------------

# Open-Meteo (free, no key required — leave as-is)
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# Perenual plant API — free tier: 100 req/day
# Get a key at https://perenual.com/docs/api
# Optional — only used for the global plant search feature.
# The built-in 40+ Mauritius plants work without this.
PERENUAL_API_KEY=

# Google Gemini — used for smart companion-planting checks
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# HuggingFace — used for garden photo segmentation
# Get a token at https://huggingface.co → Settings → Access Tokens
# Only needed when USE_MOCK_MODEL=false
HF_API_TOKEN=
